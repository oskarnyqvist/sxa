# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=data.sxa.se
DJANGO_CSRF_TRUSTED_ORIGINS=https://data.sxa.se,https://starsandcomets.sxa.se

# Postgres (use the shared instance from infra/)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sxa_data
POSTGRES_USER=sxa_data
POSTGRES_PASSWORD=change-me

# Cookies shared across *.sxa.se so the game frontend can call the API logged in
SESSION_COOKIE_DOMAIN=.sxa.se
CSRF_COOKIE_DOMAIN=.sxa.se

# CORS — list every game origin that should be allowed to call us with credentials
CORS_ALLOWED_ORIGINS=https://starsandcomets.sxa.se

# Where to send the user after login/logout. Override per deploy if needed.
LOGIN_REDIRECT_URL=https://starsandcomets.sxa.se/
LOGOUT_REDIRECT_URL=https://starsandcomets.sxa.se/

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URI: https://data.sxa.se/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
