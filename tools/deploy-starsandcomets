#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

GAME_DIR="$REPO_ROOT/games/starsandcomets"
LOCAL_WWW="$REPO_ROOT/infra/www/starsandcomets"

export SOPS_AGE_KEY_FILE="${SOPS_AGE_KEY_FILE:-$REPO_ROOT/secrets/age-key.txt}"
SERVER_IP="$(sops -d "$REPO_ROOT/secrets/hetzner.sops.env" | awk -F'"' '/^HETZNER_IP=/ {print $2}')"

echo "→ Building starsandcomets"
cd "$GAME_DIR"
npm run build

echo "→ Updating infra/www/starsandcomets"
rm -rf "$LOCAL_WWW"
cp -r "$GAME_DIR/dist" "$LOCAL_WWW"

echo "→ Syncing to $SERVER_IP"
ssh "root@$SERVER_IP" "mkdir -p /root/sxa/infra/www/starsandcomets"
rsync -avz --delete "$LOCAL_WWW/" "root@$SERVER_IP:/root/sxa/infra/www/starsandcomets/"

echo "→ Updating Caddyfile"
scp "$REPO_ROOT/infra/Caddyfile" "root@$SERVER_IP:/root/sxa/infra/Caddyfile"
ssh "root@$SERVER_IP" "cd /root/sxa/infra && docker compose exec -T caddy caddy reload --config /etc/caddy/Caddyfile"

echo "✓ Deployed: https://starsandcomets.sxa.se"
